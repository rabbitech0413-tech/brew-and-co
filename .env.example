# n8n webhook URLs — one workflow (Webhook node, POST) per form.
# Copy this file to .env.local and fill in the Production URLs from n8n.
# In Vercel, set the same keys under Settings → Environment Variables
# (Production + Preview). These are server-side only (no NEXT_PUBLIC_ prefix).

# Reservations form (app/reservations/actions.ts)
N8N_RESERVATION_WEBHOOK_URL=

# Footer newsletter signup (app/actions.ts)
N8N_NEWSLETTER_WEBHOOK_URL=

# Complaints & feedback form (app/complaints/actions.ts)
N8N_COMPLAINTS_WEBHOOK_URL=
