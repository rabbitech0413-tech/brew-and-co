{
  "$description": "Brew & Co design tokens as flat JSON, mirroring tokens/tokens.css. For design tools (Figma token plugins, etc.) or scripts. The CSS file in this same folder is the source of truth for the app itself.",
  "color": {
    "cherry": { "50": "#fbebe9", "300": "#c96b64", "DEFAULT": "#9c2b33", "700": "#7a2029" },
    "gold": { "300": "#dcb877", "DEFAULT": "#c08a34", "700": "#96691f" },
    "espresso": { "300": "#6b4a37", "DEFAULT": "#2a1b12", "900": "#170f0a" },
    "latte": { "100": "#f0e0c4", "DEFAULT": "#e4c9a0" },
    "crema": { "100": "#fbf7ef", "DEFAULT": "#f6eee1" },
    "ink": { "DEFAULT": "#1e1611", "muted": "#5c4d40" }
  },
  "font": {
    "display": { "family": "Fraunces", "role": "headlines, section titles, pull quotes", "source": "next/font/google" },
    "body": { "family": "Work Sans", "role": "paragraphs, nav, buttons, form labels", "source": "next/font/google" },
    "mono": { "family": "IBM Plex Mono", "role": "prices, order numbers, roast %, table data", "source": "next/font/google" }
  },
  "fontSize": {
    "xs": "0.75rem",
    "sm": "0.875rem",
    "base": "1rem",
    "md": "1.125rem",
    "lg": "1.375rem",
    "xl": "1.75rem",
    "2xl": "2.25rem",
    "3xl": "2.875rem",
    "4xl": "3.75rem",
    "5xl": "4.75rem"
  },
  "spacing": {
    "sip": "0.25rem",
    "cup": "0.5rem",
    "mug": "1rem",
    "pot": "1.5rem",
    "carafe": "2.5rem",
    "urn": "4rem",
    "roastery": "6rem"
  },
  "layout": {
    "containerBrew": "72rem",
    "breakpoints": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px" }
  },
  "radius": {
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "1rem",
    "pill": "999px"
  },
  "shadow": {
    "card": "0 12px 32px -16px rgb(42 27 18 / 0.35)",
    "lift": "0 24px 48px -20px rgb(42 27 18 / 0.45)"
  },
  "motion": {
    "ease": { "brew": "cubic-bezier(0.22, 1, 0.36, 1)" },
    "duration": { "fast": "150ms", "base": "240ms", "slow": "420ms" }
  },
  "gradient": {
    "roast": {
      "value": "linear-gradient(90deg, #9c2b33 0%, #c08a34 50%, #2a1b12 100%)",
      "stops": ["cherry #9c2b33", "gold #c08a34", "espresso #2a1b12"],
      "description": "Signature motif — traces the literal color change of a coffee cherry as it roasts. See style-guide.md §7."
    }
  }
}
